import numpy as np
import pandas as pd
from flask import Flask, render_template, request, redirect, url_for
from joblib import load

# ---------------------------------------------------------
# Setup and Initialization
# ---------------------------------------------------------
app = Flask(__name__)

# Load the trained machine learning model and standard scaler
model = load('floods.save')
sc = load('transform.save')

# ---------------------------------------------------------
# Page Routing
# ---------------------------------------------------------

@app.route('/')
def home():
    """Renders the landing page explaining the project."""
    return render_template('home.html')


@app.route('/predict')
def index():
    """Renders the input form for weather parameters."""
    return render_template('index.html')


@app.route('/chance')
def chance():
    """Displays an alert page if a flood is predicted."""
    return render_template('chance.html')


@app.route('/no_chance')
def no_chance():
    """Displays a safe page if no flood is predicted."""
    return render_template('no_chance.html')


# ---------------------------------------------------------
# Prediction Logic
# ---------------------------------------------------------

@app.route('/predict_flood', methods=['POST'])
def predict_flood():
    """
    Receives weather parameters via a POST request from the HTML form,
    transforms the inputs using the saved scaler, runs the XGBoost model,
    and redirects the user to the appropriate outcome page.
    """
    if request.method == 'POST':
        try:
            # 1. Extract values from the form inputs
            cloud_cover = float(request.form.get('cloud_cover', 0))
            annual_rainfall = float(request.form.get('annual_rainfall', 0))
            jan_feb = float(request.form.get('jan_feb', 0))
            march_may = float(request.form.get('march_may', 0))
            june_sept = float(request.form.get('june_sept', 0))

            # 2. Structure input values into a DataFrame with matching feature names
            feature_names = [
                'Cloud Cover', 
                'Annual Rain Fall', 
                'Jan-Feb Rainfall', 
                'March-May Rainfall', 
                'June-September'
            ]
            
            input_data = pd.DataFrame(
                [[cloud_cover, annual_rainfall, jan_feb, march_may, june_sept]], 
                columns=feature_names
            )

            # 3. Apply the saved StandardScaler to transform inputs
            scaled_features = sc.transform(input_data)

            # 4. Pass scaled data to the loaded XGBoost model for prediction
            prediction = model.predict(scaled_features)

            # 5. Redirect based on model output (1 = Flood Risk, 0 = Safe)
            if prediction[0] == 1:
                return redirect(url_for('chance'))
            else:
                return redirect(url_for('no_chance'))

        except Exception as e:
            print(f"Error encountered during prediction: {e}")
            return "An error occurred while processing your request. Please check your inputs.", 400


if __name__ == '__main__':
    app.run(debug=True)
