
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Floods Prediction - Form</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='main.css') }}">
</head>
<body>
    <nav class="navbar">
        <span class="logo">Floods Prediction</span>
        <div class="nav-links"><a href="{{ url_for('home') }}">Home</a></div>
    </nav>
    <div class="form-wrapper">
        <form action="/predict_flood" method="POST">
            <div class="form-grid">
                <div class="form-group">
                    <label>Cloud Cover</label>
                    <input type="number" step="any" name="cloud_cover" placeholder="Cloud Cover Percentage (%)" required>
                </div>
                <div class="form-group">
                    <label>Annual Rain Fall</label>
                    <input type="number" step="any" name="annual_rainfall" placeholder="Enter Annual Rain Fall in mm" required>
                </div>
                <div class="form-group">
                    <label>Jan-Feb Rainfall</label>
                    <input type="number" step="any" name="jan_feb" placeholder="Jan-Feb Rainfall in mm" required>
                </div>
                <div class="form-group invisible-spacer"></div>
                <div class="form-group">
                    <label>March-May Rainfall</label>
                    <input type="number" step="any" name="march_may" placeholder="March-May Rainfall in mm" required>
                </div>
                <div class="form-group">
                    <label>June-September</label>
                    <input type="number" step="any" name="june_sept" placeholder="June September Rainfall in mm" required>
                </div>
            </div>
            <div class="button-container">
                <button type="submit" class="btn-submit">Predict</button>
            </div>
        </form>
    </div>
</body>
</html>
